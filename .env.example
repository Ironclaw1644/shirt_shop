NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_REPLACE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_REPLACE
RESEND_FROM_EMAIL=hello@gaprinthub.com
RESEND_ADMIN_EMAIL=orders@gaprinthub.com

# Google Gemini — Nano Banana 2 image generation
GOOGLE_API_KEY=AIza...REPLACE

# Site config
NEXT_PUBLIC_SITE_URL=https://gaprinthub.com
